# Frontend (Vite)
# Copia este archivo como .env y completa los valores.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_CLIENT_ID=

# Si tu proyecto usa la clave publishable antigua, puedes dejarla aqui
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Fanatico (opcional)
# Si usas una funcion Edge en Supabase, define el project ID o una URL completa.
# VITE_SUPABASE_PROJECT_ID=
# VITE_FM_API_URL=

# Backend API (opcional). En local suele ser http://localhost:4000
# VITE_API_BASE_URL=

# Base pública del sitio (para OG/SEO)
VITE_SITE_URL=https://pollamundialista-et.app/

# Otros opcionales
# VITE_SUPABASE_AVATAR_BUCKET=avatars
# VITE_BRACKET_HOME_URL=https://pollamundialista-et.app/
# VITE_ADSENSE_CLIENT=
# VITE_ADSENSE_SLOT_HEADER=
# VITE_FLAG_VALUES={"share_card_spin":true,"share_card_interactive":true}

# Backend (server/Railway)
# RESEND_API_KEY=
# CONSENT_NOTIFY_FROM="Brackets <no-reply@tu-dominio.com>"
# CONSENT_NOTIFY_TO=djurado@comunica.ec
# CONSENT_NOTIFY_SUBJECT="Nuevo registro - consentimiento"
