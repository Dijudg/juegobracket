# Backend (Express)
# Copia este archivo como server/.env y completa los valores.
SUPABASE_URL=

# Service Role Key (Project Settings > API Keys > service_role)
# Nunca la uses en el frontend ni la subas al repo.
SUPABASE_SERVICE_ROLE_KEY=

# Origenes permitidos (separados por coma)
# Ejemplo: http://localhost:5173,https://tu-app.vercel.app
CORS_ORIGIN=

# Puerto local del backend
PORT=4000